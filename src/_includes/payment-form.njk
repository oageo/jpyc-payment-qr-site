<div class="box">

  <div class="field">
    <div class="is-flex is-align-items-center is-justify-content-space-between">
      <label class="label mb-0" for="merchantAddress">受取アドレス</label>
      <label class="checkbox is-size-7">
        <input type="checkbox" id="lock-address">
        固定する
      </label>
    </div>
    <div class="control mt-2">
      <input
        class="input"
        type="text"
        id="merchantAddress"
        placeholder="0x..."
        autocomplete="off"
        spellcheck="false"
      >
    </div>
    <p class="help is-danger" id="merchantAddress-error"></p>
  </div>

  <div class="field">
    <label class="label" for="amount">金額 (JPYC)</label>
    <div class="control">
      <input
        class="input"
        type="number"
        id="amount"
        placeholder="1000"
        min="0.000001"
        step="any"
      >
    </div>
    <p class="help is-danger" id="amount-error"></p>
  </div>

  <div class="field">
    <div class="is-flex is-align-items-center is-justify-content-space-between">
      <label class="label mb-0" for="network">ネットワーク</label>
      <label class="checkbox is-size-7">
        <input type="checkbox" id="testnet-toggle">
        テストネット
      </label>
    </div>
    <div class="control mt-2">
      <div class="select">
        <select id="network">
          <option value="polygon" selected>Polygon</option>
          <option value="ethereum">Ethereum</option>
          <option value="avalanche">Avalanche</option>
        </select>
      </div>
    </div>
  </div>


</div>
